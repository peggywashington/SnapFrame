{
  "manifest_version": 3,
  "name": "SnapFrame",
  "version": "2.0",
  "description": "Overlay a draggable crop frame on any webpage and export pixel-perfect screenshots.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SnapFrame 截图框",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  }
}
